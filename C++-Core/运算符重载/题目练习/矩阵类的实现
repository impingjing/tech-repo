//Vector2D中的属性有x,y
//重载>>
istream& operator>>(istream& in,Vector2D& v){
    char ch; 
    in >> ch; //获得'('这个字符

    in >> v.x >> ch; //获得','
    in >> v.y >> ch; //获得')'
    
    return in;
}
